// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "buffer_line_height": {
    "custom": 1.5,
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "VSCode Great Icons Theme",
  },
  "use_system_path_prompts": true,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "soft_wrap": "editor_width",
  "cursor_blink": false,
  "disable_ai": true,
  "languages": {
    "Typst": {
      "hard_tabs": true,
      "tab_size": 3,
    },
    "Go": {
      "tab_size": 3,
    },
  },
  "minimap": {
    "show": "never",
  },
  "base_keymap": "SublimeText",
  "auto_update": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Vercel Dark",
  },
  "lsp": {
    "tinymist": {
      "settings": {
        "syntaxOnly": "enable",
      },
    },
  },
}
